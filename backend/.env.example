PG_HOST=postgres
PG_PORT=5432
PG_DATABASE=duanflutter
PG_USER=postgres
PG_PASSWORD=123456
PORT=3001

# Firebase Admin (project: mediremind-79)
# Cach 1 (de nhat): tai file JSON tu Firebase Console va dat ten:
#   backend/secrets/firebase-service-account.json
# Sau do: docker compose restart backend

# Cach 2: copy 3 gia tri tu file JSON vao day
# FIREBASE_PROJECT_ID=mediremind-79
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@mediremind-79.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Cach 3: duong dan file trong container Docker
# FIREBASE_SERVICE_ACCOUNT_PATH=/usr/src/app/firebase-service-account.json
